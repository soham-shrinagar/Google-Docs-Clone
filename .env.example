# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/collabdocs?sslmode=require"
# Driver: pg (default, stable pool) | ws (Neon WebSocket) | http (Neon HTTP)
DATABASE_DRIVER=pg
# Optional: skip WSL DNS — set Neon IPv4 from `nslookup your-host.neon.tech 8.8.8.8`
# Example: DATABASE_HOST=54.86.249.90
# DATABASE_HOST=
# Optional: comma-separated DNS servers (default: 8.8.8.8,1.1.1.1)
# DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Frontend (Vite) — leave empty to use dev-server proxy (recommended)
VITE_API_URL=""
VITE_WS_URL=""

# Email (for share invites) — Gmail example: use an App Password
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CollabDocs <noreply@yourdomain.com>"

# AI (OpenAI — server-side only, never expose via VITE_*)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_WHISPER_MODEL="whisper-1"
AI_PROVIDER="openai"
