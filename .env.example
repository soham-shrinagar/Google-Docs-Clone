# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/collabdocs?sslmode=require"
# Driver: pg (default, stable pool) | ws (Neon WebSocket) | http (Neon HTTP)
DATABASE_DRIVER=pg
# Optional: skip WSL DNS — set Neon IPv4 from `nslookup your-host.neon.tech 8.8.8.8`
# Example: DATABASE_HOST=54.86.249.90
# DATABASE_HOST=
# Optional: comma-separated DNS servers (default: 8.8.8.8,1.1.1.1)
# DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth
# Local:  http://localhost:5173/api/auth/google/callback  (via Vite proxy)
# Prod:   https://google-docs-clone-backend-one.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5173/api/auth/google/callback"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"
# Production (Render): set to your Vercel URL — required for Google OAuth
# PUBLIC_APP_URL="https://google-docs-clone-backend-one.vercel.app"

# Frontend (Vite) — leave empty to use dev-server proxy (recommended)
VITE_API_URL=""
VITE_WS_URL=""

# Email
# ── Local dev: Gmail SMTP (port 465 works on your machine)
SMTP_HOST=""
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CollabDocs <your@gmail.com>"

# ── Production on Render FREE tier: SMTP ports 465/587 are BLOCKED (timeouts).
#    Use Brevo HTTP API instead (HTTPS, works on free Render). https://www.brevo.com
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="your-verified-sender@yourdomain.com"
BREVO_SENDER_NAME="CollabDocs"

# Alternative: Resend (https://resend.com)
# RESEND_API_KEY=""
# RESEND_FROM="CollabDocs <onboarding@resend.dev>"

# AI (OpenAI — server-side only, never expose via VITE_*)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_WHISPER_MODEL="whisper-1"
AI_PROVIDER="openai"
