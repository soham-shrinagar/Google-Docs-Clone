generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PermissionRole {
  OWNER
  EDITOR
  COMMENTER
  VIEWER
}

enum ActivityType {
  CREATED
  EDITED
  RENAMED
  SHARED
  DELETED
  RESTORED
  JOINED
  LEFT
  COMMENTED
  UPLOADED
  EXPORTED
}

enum DocumentType {
  RICH_TEXT
  WORKSPACE
}

enum NotificationType {
  USER_JOINED
  USER_LEFT
  DOCUMENT_SHARED
  VERSION_RESTORED
  CONNECTION_LOST
  CONNECTION_RESTORED
  CONFLICT_RESOLVED
  DOCUMENT_SAVED
}

enum AiRequestType {
  REWRITE
  GRAMMAR
  SUMMARIZE
  CHAT
  INSIGHTS
  SPEECH
  VOICE_COMMAND
  SPELL_CHECK
}

enum AiRequestStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum AiRewriteAction {
  IMPROVE
  FIX_GRAMMAR
  PROFESSIONAL
  CASUAL
  SHORTEN
  EXPAND
  SIMPLIFY
  TECHNICAL
  FORMAL
  FRIENDLY
  SUMMARIZE
  EXPLAIN
  TRANSLATE
}

enum SummaryFormat {
  BRIEF
  DETAILED
  BULLETS
  EXECUTIVE
  MEETING_NOTES
  ACTION_ITEMS
}

enum OtpPurpose {
  SIGNUP
  LOGIN
  RESET_PASSWORD
}

model EmailOtp {
  id        String     @id @default(uuid())
  email     String
  codeHash  String
  purpose   OtpPurpose
  attempts  Int        @default(0)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([email, purpose])
  @@map("email_otps")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  avatar        String?
  googleId      String?  @unique
  passwordHash  String?
  color         String   @default("#3B82F6")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedDocuments    Document[]           @relation("DocumentOwner")
  permissions       DocumentPermission[]
  operations        DocumentOperation[]
  versions          DocumentVersion[]
  activeSessions    ActiveSession[]
  presence          UserPresence[]
  activities        ActivityLog[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  pinnedDocuments   PinnedDocument[]
  recentlyOpened    RecentlyOpened[]
  comments          DocumentComment[]
  aiRequests        AiRequest[]
  aiRewrites        AiRewrite[]
  speechTranscripts SpeechTranscript[]
  userDictionary    UserDictionaryWord[]
  grammarSuggestions GrammarSuggestion[]
  aiUsageStats      AiUsageStat[]
  documentSummaries DocumentSummary[]

  @@map("users")
}

model Document {
  id           String       @id @default(uuid())
  title        String       @default("Untitled Document")
  documentType DocumentType @default(RICH_TEXT)
  content      Bytes?
  seedContent  Json?
  workspaceMeta Json?
  thumbnail    String?
  ownerId      String
  isPinned     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner           User                 @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  permissions     DocumentPermission[]
  versions        DocumentVersion[]
  snapshots       DocumentSnapshot[]
  operations      DocumentOperation[]
  activeSessions  ActiveSession[]
  presence        UserPresence[]
  activities      ActivityLog[]
  notifications   Notification[]
  pinnedBy        PinnedDocument[]
  recentlyOpened  RecentlyOpened[]
  comments        DocumentComment[]
  aiRequests      AiRequest[]
  aiRewrites      AiRewrite[]
  speechTranscripts SpeechTranscript[]
  grammarSuggestions GrammarSuggestion[]
  documentSummaries DocumentSummary[]
  assets          WorkspaceAsset[]
  workspacePages  WorkspacePage[]
  workspaceElements WorkspaceElement[]
  exports         DocumentExport[]

  @@index([ownerId])
  @@index([updatedAt])
  @@index([documentType])
  @@map("documents")
}

model DocumentPermission {
  id         String         @id @default(uuid())
  documentId String
  userId     String
  role       PermissionRole @default(VIEWER)
  shareToken String?        @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([userId])
  @@map("document_permissions")
}

model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String
  userId      String
  versionNum  Int
  label       String?
  description String?
  snapshotId  String?
  createdAt   DateTime @default(now())

  document Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot DocumentSnapshot? @relation(fields: [snapshotId], references: [id])

  @@unique([documentId, versionNum])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentSnapshot {
  id         String   @id @default(uuid())
  documentId String
  data       Bytes
  stateVector Bytes?
  wordCount  Int      @default(0)
  createdAt  DateTime @default(now())

  document Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([documentId])
  @@map("document_snapshots")
}

model DocumentOperation {
  id           String   @id @default(uuid())
  documentId   String
  userId       String
  operationId  String
  operationType String
  payload      Bytes
  vectorClock  Json?
  lamportTs    BigInt   @default(0)
  clientId     String?
  createdAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@index([documentId, lamportTs])
  @@map("document_operations")
}

model ActiveSession {
  id         String   @id @default(uuid())
  userId     String
  documentId String?
  socketId   String   @unique
  ipAddress  String?
  userAgent  String?
  connectedAt DateTime @default(now())
  lastActive DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([documentId])
  @@map("active_sessions")
}

model UserPresence {
  id         String   @id @default(uuid())
  userId     String
  documentId String
  cursorPos  Json?
  selection  Json?
  isTyping   Boolean  @default(false)
  isOnline   Boolean  @default(true)
  lastActive DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([documentId])
  @@map("user_presence")
}

model ActivityLog {
  id         String       @id @default(uuid())
  userId     String
  documentId String?
  type       ActivityType
  metadata   Json?
  createdAt  DateTime     @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([documentId, createdAt])
  @@index([userId])
  @@map("activity_logs")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  documentId String?
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  metadata   Json?
  createdAt  DateTime         @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("audit_logs")
}

model PinnedDocument {
  id         String   @id @default(uuid())
  userId     String
  documentId String
  pinnedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@map("pinned_documents")
}

model RecentlyOpened {
  id         String   @id @default(uuid())
  userId     String
  documentId String
  openedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId, openedAt])
  @@map("recently_opened")
}

model DocumentComment {
  id         String   @id @default(uuid())
  documentId String
  userId     String
  content    String
  quote      String?
  parentId   String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   DocumentComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  DocumentComment[] @relation("CommentReplies")

  @@index([documentId, createdAt])
  @@map("document_comments")
}

model AiRequest {
  id           String          @id @default(uuid())
  userId       String
  documentId   String?
  type         AiRequestType
  status       AiRequestStatus @default(PENDING)
  action       String?
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?
  metadata     Json?
  error        String?
  createdAt    DateTime        @default(now())
  completedAt  DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([documentId, createdAt])
  @@map("ai_requests")
}

model AiRewrite {
  id           String          @id @default(uuid())
  userId       String
  documentId   String
  requestId    String?
  action       AiRewriteAction
  originalText String
  resultText   String
  accepted     Boolean?
  createdAt    DateTime        @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@index([userId])
  @@map("ai_rewrites")
}

model SpeechTranscript {
  id           String   @id @default(uuid())
  userId       String
  documentId   String
  language     String   @default("en-US")
  transcript   String
  durationMs   Int?
  insertMode   String?
  wordCount    Int      @default(0)
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@map("speech_transcripts")
}

model UserDictionaryWord {
  id        String   @id @default(uuid())
  userId    String
  word      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId])
  @@map("user_dictionary")
}

model GrammarSuggestion {
  id           String   @id @default(uuid())
  userId       String
  documentId   String
  originalText String
  suggestion   String
  explanation  String?
  issueType    String
  accepted     Boolean?
  ignored      Boolean  @default(false)
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@map("grammar_suggestions")
}

model AiUsageStat {
  id                  String   @id @default(uuid())
  userId              String
  date                DateTime @db.Date
  rewriteCount        Int      @default(0)
  grammarFixCount     Int      @default(0)
  dictationCount      Int      @default(0)
  summarizeCount      Int      @default(0)
  chatCount           Int      @default(0)
  acceptedSuggestions Int      @default(0)
  rejectedSuggestions Int      @default(0)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("ai_usage_stats")
}

model DocumentSummary {
  id         String        @id @default(uuid())
  userId     String
  documentId String
  format     SummaryFormat
  content    String
  sourceHash String?
  createdAt  DateTime      @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@map("document_summaries")
}

model WorkspaceAsset {
  id           String   @id @default(uuid())
  documentId   String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  scanStatus   String   @default("pending")
  createdAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("workspace_assets")
}

model WorkspacePage {
  id             String   @id @default(uuid())
  documentId     String
  pageIndex      Int
  width          Float    @default(816)
  height         Float    @default(1056)
  backgroundType String   @default("blank")
  backgroundUrl  String?
  backgroundMeta Json?
  label          String?
  createdAt      DateTime @default(now())

  document Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  elements WorkspaceElement[]

  @@index([documentId, pageIndex])
  @@map("workspace_pages")
}

model WorkspaceElement {
  id         String   @id @default(uuid())
  documentId String
  pageId     String
  type       String
  layer      String   @default("drawing")
  zIndex     Int      @default(0)
  transform  Json
  style      Json?
  data       Json     @default("{}")
  locked     Boolean  @default(false)
  visible    Boolean  @default(true)
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  page     WorkspacePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([documentId, pageId])
  @@map("workspace_elements")
}

model DocumentExport {
  id         String   @id @default(uuid())
  documentId String
  userId     String
  format     String
  status     String   @default("completed")
  url        String?
  metadata   Json?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@map("document_exports")
}
