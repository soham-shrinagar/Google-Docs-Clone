{
  "buildCommand": "npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://collabdocs-api-3uab.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://collabdocs-api-3uab.onrender.com/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
